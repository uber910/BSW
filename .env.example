# ===== shared infrastructure =====
LOG_LEVEL=INFO

# ===== postgres =====
POSTGRES_USER=bsw
POSTGRES_PASSWORD=bsw
POSTGRES_DB=bsw

# ===== rabbitmq =====
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest

# ===== line-provider =====
LINE_PROVIDER_LOG_LEVEL=INFO
LINE_PROVIDER_HOST=0.0.0.0
LINE_PROVIDER_PORT=8000
LINE_PROVIDER_RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# ===== bet-maker =====
BET_MAKER_LOG_LEVEL=INFO
BET_MAKER_HOST=0.0.0.0
BET_MAKER_PORT=8001
BET_MAKER_POSTGRES_DSN=postgresql+asyncpg://bsw:bsw@postgres:5432/bsw
BET_MAKER_RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
BET_MAKER_LINE_PROVIDER_BASE_URL=http://line-provider:8000
BET_MAKER_RECONCILIATION_INTERVAL_S=30
